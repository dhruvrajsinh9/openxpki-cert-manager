<%- include('header') %>

<h1>My Certificates</h1>

<% if (requests.length === 0) { %>
  <p>You have no certificate requests yet. <a href="/request">Request one now</a>.</p>
<% } else { %>
  <table>
    <thead>
      <tr>
        <th>Common Name</th>
        <th>Organization</th>
        <th>Key Source</th>
        <th>Status</th>
        <th>Requested</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% requests.forEach(req => { %>
        <tr>
          <td><%= req.commonName %></td>
          <td><%= req.organization %></td>
          <td><%= req.keyGeneratedBy === 'client' ? 'Client' : 'Server' %></td>
          <td>
            <span class="status status-<%= req.status.toLowerCase() %>"><%= req.status %></span>
            <% if (req.status === 'FAILED' && req.errorMessage) { %>
              <br><small style="color: #e53e3e;"><%= req.errorMessage %></small>
            <% } %>
          </td>
          <td><%= req.createdAt.toLocaleDateString() %> <%= req.createdAt.toLocaleTimeString() %></td>
          <td>
            <a href="/certificates/<%= req._id %>" class="btn btn-primary" style="font-size: 0.75rem; padding: 0.25rem 0.5rem;">View</a>
            <% if (req.status === 'ISSUED' && req.certificatePem) { %>
              <a href="/certificates/<%= req._id %>/download" class="btn btn-success" style="font-size: 0.75rem; padding: 0.25rem 0.5rem;">Download Cert</a>
              <% if (req.privateKeyPem) { %>
                <a href="/certificates/<%= req._id %>/download-key" class="btn" style="font-size: 0.75rem; padding: 0.25rem 0.5rem; background: #805ad5; color: white;">Download Key</a>
              <% } %>
            <% } %>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
<% } %>

<%- include('footer') %>
